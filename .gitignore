# Cria o .gitignore na raiz
echo "gerador.py" >> .gitignore
echo "artigos.csv" >> .gitignore
echo "config.json" >> .gitignore
echo "templates/" >> .gitignore
echo "layout/" >> .gitignore
echo "*.py" >> .gitignore
echo "*.txt" >> .gitignore
echo "*.bat" >> .gitignore
echo ".env" >> .gitignore
echo "__pycache__/" >> .gitignore

# Adiciona o .gitignore
git add .gitignore